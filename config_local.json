{
  "model_name": "EleutherAI/pythia-70m",
  "dataset_name": "wikitext",
  "dataset_config": "wikitext-103-raw-v1",
  "dataset_split": "test[:1%]",
  "val_dataset_split": "validation[:1%]",
  "max_length": 128,
  "batch_size": 1,
  "learning_rate": 0.001,
  "epochs": 5,
  "clip_grad_norm": 1.0,
  "skip_configs": {
    "full": 0.0,
    "skip_25": 0.25,
    "skip_50": 0.5
  },
  "entropy_thresholds": [3.0, 3.5, 4.0, 4.5],
  "entropy_min_layers": 2,
  "voc_thresholds": [-1.0, -0.5, 0.0, 0.5, 1.0],
  "voc_collect_samples": 50,
  "num_layers": 6
}